# ─── CMS Service Environment Variables ───────────────────────────
#
# REQUIRED:
#   CMS_DATABASE_URL   — Separate PostgreSQL for CMS (NOT the main app DB)
#   ANTHROPIC_API_KEY  — Claude API key for AI content generation
#
# OPTIONAL:
#   SHARED_DATABASE_URL — Main app DB for event bridge (automation triggers)
#   CMS_STORAGE_ROOT    — Volume mount for media files (default: /data/cms)
#   ALLOWED_ORIGINS     — CORS origins, comma-separated
#   LOG_LEVEL           — DEBUG, INFO, WARNING, ERROR (default: INFO)
#   PORT                — HTTP port (Railway assigns dynamically)
#   GENERATION_POLL_INTERVAL — Seconds between generation polls (default: 30)
#
# ─────────────────────────────────────────────────────────────────

# CMS-specific database (separate Railway Postgres plugin)
CMS_DATABASE_URL=postgresql://user:pass@host:5432/cms_db

# Shared database for event bridge (same as frontend DATABASE_URL)
# If set, CMS events flow into the automation/event system
SHARED_DATABASE_URL=postgresql://user:pass@host:5432/main_db

# Claude API for content generation
ANTHROPIC_API_KEY=sk-ant-...

# Media storage (Railway persistent volume mount point)
CMS_STORAGE_ROOT=/data/cms

# CORS (internal Railway URL for frontend + public URL)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.up.railway.app

# Frontend URL for links in emails
FRONTEND_URL=https://rfppipeline.com

# ─── Email Engine (Gmail API via OAuth2) ──────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_WORKSPACE_EMAIL=platform@rfppipeline.com

# ─── Event Listener ──────────────────────────────────────────────
EVENT_POLL_INTERVAL=10

# Logging
LOG_LEVEL=INFO
