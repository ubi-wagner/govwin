# =============================================================================
# GovTech Intel v3 — Environment Variables
# =============================================================================

# Database (shared by pipeline + frontend)
DATABASE_URL=postgresql://govtech:changeme@localhost:5432/govtech_intel
POSTGRES_DB=govtech_intel
POSTGRES_USER=govtech
POSTGRES_PASSWORD=changeme_use_strong_password

# Auth.js
AUTH_SECRET=run_openssl_rand_base64_32_and_paste_here
AUTH_URL=http://localhost:3000

# Email (for magic links + notifications)
AUTH_RESEND_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# Encryption key for API keys stored in DB (rotate via admin UI)
# Generate with: openssl rand -base64 32
API_KEY_ENCRYPTION_SECRET=run_openssl_rand_base64_32_and_paste_here

# Pipeline API Keys (env var fallback — prefer rotating via admin UI)
SAM_GOV_API_KEY=your_sam_gov_api_key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# Local file storage (Railway volume)
# Mount a persistent volume at this path in Railway
STORAGE_ROOT=/data

# Google Workspace (deferred — for email/marketing integration later)
# GOOGLE_SERVICE_ACCOUNT_KEY=base64_encoded_service_account_json_key
# GOOGLE_DELEGATED_ADMIN=admin@rfppipeline.com
# GOOGLE_DELEGATED_SENDER=admin@rfppipeline.com
# GOOGLE_WORKSPACE_DOMAIN=rfppipeline.com

# App
APP_ENV=development
