# =============================================================================
# RFP Pipeline — Environment Variables
# =============================================================================
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in all values marked with [REQUIRED] below
#   3. .env is gitignored — your secrets will NOT be committed
#   4. Railway users: these same variables go in Railway service settings
#      (run `make railway-vars` for a per-service cheat sheet)
#
# LEGEND:
#   [REQUIRED]    — App will not start without this
#   [SECRET]      — Sensitive credential — never commit the real value
#   [RECOMMENDED] — Not strictly required but expected for production use
#   [OPTIONAL]    — Has a sensible default or enables a deferred feature
#
# =============================================================================


# ─── DATABASE ────────────────────────────────────────────────────────────────
# Shared by frontend + pipeline. Both services connect to the same Postgres.
#
# Local Docker:   postgresql://govtech:changeme@localhost:5432/govtech_intel
# Railway:        Copy from Railway > Postgres service > Variables > DATABASE_URL
#
# [REQUIRED] [SECRET]
DATABASE_URL=postgresql://govtech:changeme@localhost:5432/govtech_intel

# Docker Compose only — used to initialize the local Postgres container.
# Not needed if connecting to Railway or an external DB.
POSTGRES_DB=govtech_intel
POSTGRES_USER=govtech
# [SECRET]
POSTGRES_PASSWORD=changeme_use_strong_password


# ─── AUTHENTICATION (NextAuth v5) ───────────────────────────────────────────
# AUTH_SECRET signs JWTs. Must be a strong random string.
# Generate with:  openssl rand -base64 32
#
# [REQUIRED] [SECRET]
AUTH_SECRET=<run: openssl rand -base64 32>

# Public URL of the frontend app. Used for auth redirects and callbacks.
# Local dev: http://localhost:3000
# Railway:   https://your-app.up.railway.app  (your actual Railway domain)
#
# [REQUIRED]
AUTH_URL=http://localhost:3000

# Public-facing app URL (available client-side via Next.js NEXT_PUBLIC_ prefix).
# Should match AUTH_URL unless you run behind a reverse proxy that rewrites.
#
# [OPTIONAL]
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── ENCRYPTION ──────────────────────────────────────────────────────────────
# Master key for AES-256-GCM encryption of API keys stored in the DB.
# The same key MUST be set on both frontend and pipeline services —
# frontend encrypts, pipeline decrypts.
# Generate with:  openssl rand -base64 32
#
# [REQUIRED] [SECRET]
API_KEY_ENCRYPTION_SECRET=<run: openssl rand -base64 32>


# ─── SAM.GOV API ────────────────────────────────────────────────────────────
# Federal opportunities data source. Register at https://sam.gov/content/home
# and request an API key under "System Account" > "Public API Key".
#
# This is the env var fallback. Once you load the key through the admin UI
# (Sources page), the encrypted DB copy takes priority over this value.
#
# [RECOMMENDED] [SECRET]
SAM_GOV_API_KEY=<your SAM.gov public API key>


# ─── ANTHROPIC (Claude AI) ──────────────────────────────────────────────────
# Powers the agent fabric: RFP shredding, section drafting, compliance review,
# opportunity analysis. Get a key at https://console.anthropic.com
#
# Like SAM.gov, this is the env var fallback — the admin UI encrypted copy
# takes priority once loaded through the Sources page.
#
# [RECOMMENDED] [SECRET]
ANTHROPIC_API_KEY=<your Anthropic API key — starts with sk-ant->

# Which Claude model to use. Default is recommended.
# [OPTIONAL] — default: claude-sonnet-4-20250514
CLAUDE_MODEL=claude-sonnet-4-20250514


# ─── FILE STORAGE ────────────────────────────────────────────────────────────
# Root directory for local file cache (paths like cached RFP documents).
# The authoritative storage in V2 is the Railway S3-compatible bucket —
# see the AWS BUCKET section below. Local dev uses this path as a fallback.
#
# Local dev:  ./data  (or any writable path)
# Railway:    /data   (mount a Railway volume at /data)
#
# [REQUIRED]
STORAGE_ROOT=/data


# ─── AWS S3 BUCKET (Railway-managed) ────────────────────────────────────────
# These five variables are injected automatically by Railway when the
# S3-compatible bucket service is linked to frontend and pipeline. You
# do NOT set these manually in .env — they come from Railway at runtime.
#
# They are listed here for documentation only:
#
#   AWS_ACCESS_KEY_ID       — bucket access key
#   AWS_SECRET_ACCESS_KEY   — bucket secret
#   AWS_DEFAULT_REGION      — "auto"
#   AWS_ENDPOINT_URL        — https://t3.storageapi.dev
#   AWS_S3_BUCKET_NAME      — rfp-pipeline-prod-<hash>
#
# See docs/STORAGE_LAYOUT.md for the 3-folder bucket structure
# (rfp-admin/, rfp-pipeline/, customers/).


# ─── STRIPE (Payments) ──────────────────────────────────────────────────────
# Stripe subscription + one-time payment support.
# Get keys from https://dashboard.stripe.com/apikeys
# Webhook secret from https://dashboard.stripe.com/webhooks
#
# [RECOMMENDED — required for Phase 2 checkout] [SECRET]
STRIPE_SECRET_KEY=<your Stripe secret key — starts with sk_live_ or sk_test_>
STRIPE_WEBHOOK_SECRET=<your Stripe webhook signing secret — starts with whsec_>

# Stripe price IDs for each product tier.
# Create products in Stripe Dashboard > Products, then copy the price IDs here.
#
# [RECOMMENDED]
STRIPE_PRICE_FINDER=<price ID for $199/month Finder subscription>
STRIPE_PRICE_PHASE1=<price ID for $999 Phase I proposal one-time>
STRIPE_PRICE_PHASE2=<price ID for $2500 Phase II proposal one-time>


# ─── EMAIL (Resend) ──────────────────────────────────────────────────────────
# Used for email notifications (digests, deadline alerts, onboarding,
# invite temp passwords, password reset). Get a key at https://resend.com
#
# NOTE: renamed from AUTH_RESEND_KEY in pre-V2 to RESEND_API_KEY in V2.
# Any pre-V2 config referencing AUTH_RESEND_KEY must be updated.
#
# [RECOMMENDED] [SECRET]
RESEND_API_KEY=<your Resend.com API key — starts with re_>

# Sender address for outbound emails.
# [OPTIONAL]
EMAIL_FROM=noreply@rfppipeline.com


# ─── PIPELINE SETTINGS ──────────────────────────────────────────────────────
# Feature flag: set to "true" to use generated stub data instead of real
# SAM.gov API calls. Useful for development without an API key.
#
# [OPTIONAL] — default: false
USE_STUB_DATA=false

# Pipeline logging level.
# [OPTIONAL] — default: INFO
LOG_LEVEL=INFO

# Allow the schema-wiping migration (000_drop_all.sql) to run.
# MUST be unset or "false" in production. Only set to "true" during
# V1 pre-launch clean-build cycles.
#
# [OPTIONAL] — default: false
ALLOW_SCHEMA_RESET=false


# ─── APP ─────────────────────────────────────────────────────────────────────
# General application environment indicator.
#
# [OPTIONAL] — default: development
APP_ENV=development

# Node environment. Set to "production" for deployed environments.
# Docker and Railway set this automatically.
#
# [OPTIONAL] — default: development
NODE_ENV=development


# ─── CMS SERVICE (V1 dormant, deferred to V2+) ──────────────────────────────
# The CMS service is scaffolded but not deployed in V1. These variables
# are only relevant if you opt into the `cms` docker-compose profile
# (`docker compose --profile cms up -d`).
#
# [OPTIONAL]
CMS_SERVICE_URL=http://cms:8000
CMS_DATABASE_URL=postgresql://govtech_cms:cms_dev_password@cms-db:5432/govtech_cms
CMS_POSTGRES_DB=govtech_cms
CMS_POSTGRES_USER=govtech_cms
# [SECRET]
CMS_POSTGRES_PASSWORD=cms_dev_password


# ─── TESTING (Dev only) ─────────────────────────────────────────────────────
# These are only needed when running the test suite locally.
# They are NOT needed in production or Railway.
#
# Separate test database to avoid polluting dev data.
# [OPTIONAL]
# TEST_DATABASE_URL=postgresql://govtech:changeme@localhost:5432/govtech_intel_test

# Base URL for E2E / integration test HTTP requests.
# [OPTIONAL] — default: http://localhost:3099
# TEST_BASE_URL=http://localhost:3099
