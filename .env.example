# =============================================================================
# GovTech Intel v3 — Environment Variables
# =============================================================================

# Database (shared by pipeline + frontend)
DATABASE_URL=postgresql://govtech:changeme@localhost:5432/govtech_intel
POSTGRES_DB=govtech_intel
POSTGRES_USER=govtech
POSTGRES_PASSWORD=changeme_use_strong_password

# Auth.js
AUTH_SECRET=run_openssl_rand_base64_32_and_paste_here
AUTH_URL=http://localhost:3000

# Email (for magic links + notifications)
AUTH_RESEND_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# Pipeline API Keys
SAM_GOV_API_KEY=your_sam_gov_api_key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google OAuth (user login with Drive access)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google Workspace Integration (service account for automation)
GOOGLE_SERVICE_ACCOUNT_KEY=base64_encoded_service_account_json_key
GOOGLE_DELEGATED_ADMIN=admin@yourdomain.com
GOOGLE_DELEGATED_SENDER=noreply@yourdomain.com
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_root_folder_id
GOOGLE_WORKSPACE_DOMAIN=yourdomain.com

# App
APP_ENV=development
DOCUMENT_STORE_PATH=./docs/opportunity_store
UPLOAD_STORE_PATH=./docs/uploads
