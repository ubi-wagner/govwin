{
  "name": "govtech-intel-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run --exclude '__tests__/integration/**'",
    "test:unit": "vitest run __tests__/api-guards.test.ts __tests__/middleware.test.ts",
    "test:integration": "vitest run __tests__/integration/",
    "test:e2e": "playwright test",
    "test:server": "next dev --port 3099",
    "test:all": "bash ../scripts/test-all.sh",
    "test:ci": "bash ../scripts/test-all.sh --ci"
  },
  "dependencies": {
    "@auth/pg-adapter": "^1.11.1",
    "@tanstack/react-query": "^5.91.3",
